					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [ "pm.test('OK (200)', () => pm.response.to.have.status(200));" ]
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/reservations/user/{{userId}}",
					"host": [ "{{baseUrl}}" ],
					"path": [ "api", "reservations", "user", "{{userId}}" ]
				}
			}
		},
		{
			"name": "5. Get Reservations By Driver",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [ "pm.test('OK (200)', () => pm.response.to.have.status(200));" ]
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/reservations/driver/{{driverId}}",
					"host": [ "{{baseUrl}}" ],
					"path": [ "api", "reservations", "driver", "{{driverId}}" ]
				}
			}
		},
		{
			"name": "6. Get Reservations By Trajet",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [ "pm.test('OK (200)', () => pm.response.to.have.status(200));" ]
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/reservations/trajet/{{trajetId}}",
					"host": [ "{{baseUrl}}" ],
					"path": [ "api", "reservations", "trajet", "{{trajetId}}" ]
				}
			}
		},
		{
