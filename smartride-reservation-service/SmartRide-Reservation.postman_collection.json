			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [ "pm.test('OK (200)', () => pm.response.to.have.status(200));" ]
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/reservations/status/{{status}}",
					"host": [ "{{baseUrl}}" ],
					"path": [ "api", "reservations", "status", "{{status}}" ]
				},
				"description": "status path variable accepts: PENDING, CONFIRMED, COMPLETED, CANCELLED."
			}
		},
		{
			"name": "8. Update Reservation (PENDING only)",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [ "pm.test('OK (200)', () => pm.response.to.have.status(200));" ]
					}
				}
			],
			"request": {
				"method": "PUT",
				"header": [ { "key": "Content-Type", "value": "application/json" } ],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"userId\": {{userId}},\n  \"trajetId\": {{trajetId}},\n  \"nombrePassagers\": 3\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": {
					"raw": "{{baseUrl}}/api/reservations/{{reservationId}}",
					"host": [ "{{baseUrl}}" ],
					"path": [ "api", "reservations", "{{reservationId}}" ]
				},
				"description": "Updates nombrePassagers/trajet and recomputes prixTotal. Only allowed while status is PENDING."
			}
		},
		{
			"name": "9. Confirm Reservation",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [ "pm.test('OK (200)', () => pm.response.to.have.status(200));" ]
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/reservations/{{reservationId}}/confirmer",
					"host": [ "{{baseUrl}}" ],
					"path": [ "api", "reservations", "{{reservationId}}", "confirmer" ]
				},
				"description": "PENDING -> CONFIRMED. Publishes reservation.confirmed (payment-service creates a payment)."
			}
		},
		{
			"name": "10. Complete Reservation",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [ "pm.test('OK (200)', () => pm.response.to.have.status(200));" ]
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/reservations/{{reservationId}}/completer",
					"host": [ "{{baseUrl}}" ],
					"path": [ "api", "reservations", "{{reservationId}}", "completer" ]
				},
				"description": "-> COMPLETED and writes a ReservationHistory entry."
			}
		},
		{
			"name": "11. Cancel Reservation (PENDING/CONFIRMED only)",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [ "pm.test('OK (200)', () => pm.response.to.have.status(200));" ]
					}
				}
			],
			"request": {
				"method": "PATCH",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/api/reservations/{{reservationId}}/annuler",
					"host": [ "{{baseUrl}}" ],
					"path": [ "api", "reservations", "{{reservationId}}", "annuler" ]
				},
				"description": "-> CANCELLED (within the 30-min delaiAnnulationLimite). Publishes reservation.cancelled. Fails if already COMPLETED/CANCELLED. NOTE: run this on a fresh reservation, not after '10. Complete'."
			}
		},
		{
			"name": "12. Get Historique By User",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [ "pm.test('OK (200)', () => pm.response.to.have.status(200));" ]
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
