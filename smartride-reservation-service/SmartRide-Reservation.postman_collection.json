					"host": [ "{{baseUrl}}" ],
					"path": [ "api", "reservations", "historique", "{{userId}}" ]
				},
				"description": "Returns ReservationHistory entries (created on Complete/Cancel)."
			}
		},
		{
			"name": "13. Delete Reservation",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [ "pm.test('No Content (204)', () => pm.response.to.have.status(204));" ]
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [],
